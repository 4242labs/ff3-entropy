# Copy to .env and fill in. .env is gitignored — never commit your token.

# Where your Firefly III lives, no trailing slash.
FIREFLY_III_URL=https://firefly.example.com

# Firefly III → Options → Profile → OAuth → Personal Access Tokens → Create.
# Read-only is all FF3 Entropy ever does with it.
FIREFLY_III_TOKEN=

# How many days either side of an expected date still counts as "that's the one"
# when matching a real transaction to a projected occurrence.
MATCH_DAYS=5

# Host port to serve on.
PORT=8000
